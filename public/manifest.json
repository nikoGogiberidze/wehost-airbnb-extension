{
  "manifest_version": 3,
  "name": "Wehost Airbnb Manager",
  "version": "1.0.0",
  "description": "Internal WeHost tool for managing Airbnb accounts",
  "permissions": [
    "tabs",
    "scripting",
    "storage",
    "clipboardWrite",
    "cookies"
  ],
  "host_permissions": [
    "https://www.airbnb.com/*"
  ],
  "background": {
    "service_worker": "background/service_worker.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_width": 400,
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
