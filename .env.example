# Chrome Extension (Vite build-time env vars)
VITE_API_BASE_URL=https://your-vercel-project.vercel.app
VITE_EXTENSION_API_KEY=your-secret-key-here

# Vercel serverless function (set in Vercel dashboard → Project → Settings → Environment Variables)
EXTENSION_API_KEY=your-secret-key-here
MONDAY_API_TOKEN=your-monday-api-token
MONDAY_BOARD_ID=your-monday-board-id
