# Chrome Extension (Vite build-time env vars)
VITE_API_BASE_URL=https://your-vercel-project.vercel.app
VITE_EXTENSION_API_KEY=your-secret-key-here

# Vercel serverless function (set in Vercel dashboard → Project → Settings → Environment Variables)
EXTENSION_API_KEY=your-secret-key-here
MONDAY_API_TOKEN=your-monday-api-token
MONDAY_BOARD_ID=your-monday-board-id

# Per-user auth (set in Vercel dashboard)
# AUTH_PEPPER + AUTH_JWT_SECRET: random secrets (e.g. `openssl rand -base64 24`)
AUTH_PEPPER=random-server-secret
AUTH_JWT_SECRET=random-signing-secret
# AUTH_USERS: JSON allowlist. Generate each hash with: node scripts/hash-user.js <password>
# One entry with "role":"test" returns fake demo data (for the Web Store reviewer).
AUTH_USERS=[{"email":"staff@wehost.com","hash":"<sha256(password+AUTH_PEPPER)>","role":"user"},{"email":"reviewer@wehost.com","hash":"<...>","role":"test"}]

# For local use of scripts/hash-user.js, also add AUTH_PEPPER to your local .env (gitignored).
